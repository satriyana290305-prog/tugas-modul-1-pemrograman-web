<?php

$nama = "";
$email = "";
$pesan = "";

$error = "";
$berhasil = false;

if ($_SERVER["REQUEST_METHOD"] == "POST") {

    $nama = htmlspecialchars($_POST["nama"]);
    $email = htmlspecialchars($_POST["email"]);
    $pesan = htmlspecialchars($_POST["pesan"]);

    if (empty($nama) || empty($email) || empty($pesan)) {
        $error = "Semua kolom harus diisi!";
    } else {
        $berhasil = true;
    }
}

