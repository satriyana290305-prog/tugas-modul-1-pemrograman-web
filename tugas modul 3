<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Company Profile</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background-color: #f8f9fa;
        }

        .hero {
            background: linear-gradient(to right, #0d6efd, #0dcaf0);
            color: white;
            padding: 80px 20px;
            text-align: center;
        }

        .card:hover {
            transform: scale(1.05);
            transition: 0.3s;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        }

        footer {
            background-color: #212529;
            color: white;
            padding: 20px;
            text-align: center;
            margin-top: 30px;
        }
    </style>
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="#">Tech Company</a>

            <button class="navbar-toggler" type="button"
                data-bs-toggle="collapse"
                data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link active" href="#">Home</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="#about">About</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="#services">Services</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="#contact">Contact</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Header -->
    <section class="hero">
        <h1>PT Teknologi Nusantara</h1>
        <p>Solusi Teknologi Modern untuk Masa Depan Digital</p>
    </section>

    <!-- Tabel Informasi -->
    <section class="container my-5" id="about">
        <h2 class="text-center mb-4">Informasi Perusahaan</h2>

        <table class="table table-bordered table-striped">
            <tr>
                <th>Nama Perusahaan</th>
                <td>PT Teknologi Nusantara</td>
            </tr>
            <tr>
                <th>Tahun Berdiri</th>
                <td>2015</td>
            </tr>
            <tr>
                <th>Jumlah Karyawan</th>
                <td>150 Orang</td>
            </tr>
            <tr>
                <th>Lokasi Kantor</th>
                <td>Samarinda, Kalimantan Timur</td>
            </tr>
        </table>
    </section>

    <!-- Card Produk/Layanan -->
    <section class="container my-5" id="services">
        <h2 class="text-center mb-4">Produk & Layanan</h2>

        <div class="row">

            <div class="col-md-4 mb-4">
                <div class="card h-100">
                    <img src="website.development.jfif" class="card-img-top">
                    <div class="card-body">
                        <h5 class="card-title">Website Development</h5>
                        <p class="card-text">
                            Pembuatan website profesional dan responsif.
                        </p>
                        <a href="#" class="btn btn-primary">Selengkapnya</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <div class="card h-100">
                    <img src="mobile.app.jfif" class="card-img-top">
                    <div class="card-body">
                        <h5 class="card-title">Mobile App</h5>
                        <p class="card-text">
                            Pengembangan aplikasi Android dan iOS.
                        </p>
                        <a href="#" class="btn btn-success">Selengkapnya</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <div class="card h-100">
                    <img src="cyber.security.jfif" class="card-img-top">
                    <div class="card-body">
                        <h5 class="card-title">Cyber Security</h5>
                        <p class="card-text">
                            Perlindungan data dan keamanan sistem perusahaan.
                        </p>
                        <a href="#" class="btn btn-danger">Selengkapnya</a>
                    </div>
                </div>
            </div>

        </div>
    </section>

    <!-- Footer -->
    <footer id="contact">
        <p>&copy; 2025 PT Teknologi Nusantara</p>
        <p>Email: info@teknologinusantara.com</p>
        <p>Instagram | Facebook | LinkedIn</p>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
