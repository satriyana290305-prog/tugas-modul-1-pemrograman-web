<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Toko Elektronik Cepat</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .product-img { height: 300px; object-fit: cover; }
    </style>
</head>
<body class="bg-light">

<div class="container py-4">
    <header class="d-flex justify-content-between align-items-center mb-4">
        <h1>Toko Elektronik Cepat</h1>
        <div id="clock" class="fw-bold text-primary"></div>
    </header>

    <div class="row">
        <div class="col-md-8">
            <div class="card p-3 shadow-sm">
                <img id="main-img" class="product-img card-img-top" src="" alt="Produk">
                <div class="d-flex justify-content-between my-2">
                    <button class="btn btn-secondary" onclick="gantiGambar(-1)">Previous</button>
                    <button class="btn btn-secondary" onclick="gantiGambar(1)">Next</button>
                </div>
                <h3 id="product-name"></h3>
                <p class="fs-4 text-danger" id="product-price"></p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card p-3 shadow-sm">
                <h5>Daftar Produk</h5>
                <ul id="product-list" class="list-group"></ul>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card p-4 shadow-sm">
                <h4>Form Pemesanan</h4>
                <div class="mb-2">Nama: <input type="text" id="nama" class="form-control"></div>
                <div class="mb-2">Jumlah: <input type="number" id="jumlah" class="form-control"></div>
                <div class="mb-2">Kode Promo: <input type="text" id="kode" class="form-control"></div>
                <button class="btn btn-success" onclick="prosesPesanan()">Pesan Sekarang</button>
            </div>
        </div>
        <div class="col-md-6" id="output-struk" style="display:none;">
            <div class="card p-4 bg-white border-success shadow-sm">
                <h4>Struk Pesanan</h4>
                <div id="hasil-struk"></div>
            </div>
        </div>
    </div>
</div>

<script>
    // 1. Data Produk (Array of Objects)
    const produkData = [
        { nama: "Laptop", harga: 10000000, gambar: ["https://tse1.mm.bing.net/th/id/OIP.ZRf_GbNfOgmTueABNXZPBgHaEK?pid=Api&h=220&P=01", "https://tse4.mm.bing.net/th/id/OIP.WxLsAB-XQMtZhA4u9LBqowHaEK?pid=Api&h=220&P=02"] },
        { nama: "Mouse", harga: 200000, gambar: ["https://tse2.mm.bing.net/th/id/OIP.0YZhLjzPtvSX65cDhJw-HQHaHa?pid=Api&h=220&P=01", "https://tse4.mm.bing.net/th/id/OIP.c4psGP8GIrymwzU3rJ2ZvwHaHA?pid=Api&h=220&P=02"] },
        { nama: "Monitor", harga: 2000000, gambar: ["https://tse1.mm.bing.net/th/id/OIP._9Czw8OfIGIqF5e89ZEfqQHaEK?pid=Api&h=220&P=0", "https://tse1.mm.bing.net/th/id/OIP.6edUwp8YZbxqp4O-LEVijwAAAA?pid=Api&h=220&P=0"] }
    ];

    let currentIdx = 0;
    let imgIdx = 0;

    // 2. Fungsi Jam (Date & setInterval)
    function updateJam() {
        document.getElementById('clock').innerText = new Date().toLocaleTimeString();
    }
    setInterval(updateJam, 1000);

    // 3. Render Daftar Produk
    const list = document.getElementById('product-list');
    produkData.forEach((p, i) => {
        list.innerHTML += `<li class="list-group-item list-group-item-action" onclick="pilihProduk(${i})">${p.nama}</li>`;
    });

    function pilihProduk(i) {
        currentIdx = i; imgIdx = 0;
        document.getElementById('main-img').src = produkData[i].gambar[imgIdx];
        document.getElementById('product-name').innerText = produkData[i].nama;
        document.getElementById('product-price').innerText = "Rp " + produkData[i].harga.toLocaleString();
    }

    function gantiGambar(arah) {
        imgIdx = (imgIdx + arah + produkData[currentIdx].gambar.length) % produkData[currentIdx].gambar.length;
        document.getElementById('main-img').src = produkData[currentIdx].gambar[imgIdx];
    }

    // 4. Proses Pesanan
    function prosesPesanan() {
        const nama = document.getElementById('nama').value;
        const jml = parseInt(document.getElementById('jumlah').value);
        const kode = document.getElementById('kode').value.toUpperCase();

        if (!nama || !jml || jml <= 0) { alert("Data tidak valid!"); return; }

        const subtotal = jml * produkData[currentIdx].harga;
        const diskon = (kode === "DISKON10") ? subtotal * 0.1 : 0;
        const total = subtotal - diskon;
        const orderId = "INV-" + Math.floor(10000 + Math.random() * 90000);

        document.getElementById('hasil-struk').innerHTML = `
            ID: ${orderId}<br>Nama: ${nama}<br>Produk: ${produkData[currentIdx].nama}<br>
            Subtotal: ${subtotal}<br>Potongan: ${diskon}<br><strong>Total: ${total}</strong>`;
        document.getElementById('output-struk').style.display = "block";
    }

    pilihProduk(0); // Load default
</script>
</body>
</html>
